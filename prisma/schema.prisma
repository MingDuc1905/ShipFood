// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("POSTGRES_PRISMA_URL")
  directUrl = env("POSTGRES_URL_NO_SSL")
}

model User {
  userId          Int     @id @default(autoincrement())
  username        String  @unique @db.VarChar(50)
  password        String  @db.VarChar(255)
  userType        String  @db.VarChar(50) // 'Khách hàng', 'Quán ăn', 'Shipper', 'Admin'
  phone           String  @unique @db.VarChar(11)
  balance         Float?  @default(0)
  email           String  @unique @db.VarChar(50)
  status          Int     // 0: chưa duyệt, 1: đã duyệt, 2: bị khóa, 3: inactive
  avatar          String? @db.VarChar(500)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  shipper         Shipper?
  restaurant      Restaurant?
  customer        Customer?
  admin           Admin?
  orders          Order[]
  messages        Message[]

  @@index([userType])
  @@index([status])
}

model Shipper {
  userId          Int     @id
  name            String  @db.VarChar(50)
  address         String  @db.VarChar(250)
  latitude        Float?
  longitude       Float?
  rating          Float?  @default(0)
  reviewCount     Int?    @default(0)
  status          String  @db.VarChar(50) @default("Không hoạt động") // 'Đang hoạt động', 'Không hoạt động'
  avatar          String? @db.VarChar(500)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user            User    @relation(fields: [userId], references: [userId], onDelete: Cascade)
  deliveries      Delivery[]

  @@index([status])
}

model Restaurant {
  userId          Int     @id
  name            String  @db.VarChar(100)
  address         String  @db.VarChar(250)
  latitude        Float?
  longitude       Float?
  reviewCount     Int?    @default(0)
  rating          Float?  @default(0)
  status          String  @db.VarChar(50) @default("Đóng cửa") // 'Đang mở cửa', 'Đóng cửa'
  avatar          String? @db.VarChar(500)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user            User    @relation(fields: [userId], references: [userId], onDelete: Cascade)
  menus           Menu[]
  orders          Order[]

  @@index([status])
}

model Customer {
  userId          Int     @id
  name            String  @db.VarChar(50)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user            User    @relation(fields: [userId], references: [userId], onDelete: Cascade)
  deliveryAddresses DeliveryAddress[]
  orders          Order[]
}

model Admin {
  userId          Int     @id
  permissions     String? @db.Text
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user            User    @relation(fields: [userId], references: [userId], onDelete: Cascade)
}

model Category {
  id              Int     @id @default(autoincrement())
  name            String  @db.VarChar(100)
  description     String? @db.VarChar(500)
  image           String? @db.VarChar(500)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  menus           Menu[]

  @@index([name])
}

model Menu {
  id              Int     @id @default(autoincrement())
  restaurantId    Int
  name            String  @db.VarChar(100)
  price           Float
  description     String? @db.VarChar(500)
  image           String? @db.VarChar(500)
  categoryId      Int
  status          Int     @default(1)
  rating          Float?  @default(0)
  reviewCount     Int?    @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  restaurant      Restaurant @relation(fields: [restaurantId], references: [userId], onDelete: Cascade)
  category        Category   @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  promotions      MenuPromotion[]
  orderItems      OrderItem[]

  @@index([restaurantId])
  @@index([categoryId])
  @@index([status])
}

model Promotion {
  id              Int     @id @default(autoincrement())
  name            String  @db.VarChar(100)
  description     String? @db.VarChar(500)
  type            String  @db.VarChar(50) // 'percent', 'fixed'
  value           Int     // phần trăm hoặc tiền
  minCondition    Float?  // điều kiện tối thiểu
  condition       String? @db.VarChar(500)
  startDate       DateTime
  endDate         DateTime
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  menus           MenuPromotion[]
  orders          Order[]

  @@index([startDate])
  @@index([endDate])
}

model MenuPromotion {
  id              Int     @id @default(autoincrement())
  menuId          Int
  promotionId     Int
  createdAt       DateTime @default(now())

  menu            Menu      @relation(fields: [menuId], references: [id], onDelete: Cascade)
  promotion       Promotion @relation(fields: [promotionId], references: [id], onDelete: Cascade)

  @@unique([menuId, promotionId])
  @@index([menuId])
  @@index([promotionId])
}

model Order {
  id              Int     @id @default(autoincrement())
  customerId      Int
  restaurantId    Int
  statusId        Int     @default(1) // 1: pending, 2: confirmed, 3: preparing, 4: ready, 5: delivering, 6: delivered
  totalPrice      Float
  discountAmount  Float   @default(0)
  finalPrice      Float
  promotionId     Int?
  notes           String? @db.Text
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  customer        Customer  @relation(fields: [customerId], references: [userId], onDelete: Cascade)
  restaurant      Restaurant @relation(fields: [restaurantId], references: [userId], onDelete: Cascade)
  promotion       Promotion? @relation(fields: [promotionId], references: [id])
  items           OrderItem[]
  delivery        Delivery?
  history         OrderHistory[]

  @@index([customerId])
  @@index([restaurantId])
  @@index([statusId])
  @@index([createdAt])
}

model OrderItem {
  id              Int     @id @default(autoincrement())
  orderId         Int
  menuId          Int
  quantity        Int
  price           Float
  subtotal        Float

  order           Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menu            Menu    @relation(fields: [menuId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([menuId])
}

model OrderHistory {
  id              Int     @id @default(autoincrement())
  orderId         Int
  statusId        Int
  note            String? @db.Text
  createdAt       DateTime @default(now())

  order           Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([createdAt])
}

model DeliveryAddress {
  id              Int     @id @default(autoincrement())
  customerId      Int
  phone           String  @db.VarChar(11)
  address         String  @db.VarChar(250)
  latitude        Float?
  longitude       Float?
  recipientName   String  @db.VarChar(50)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  customer        Customer @relation(fields: [customerId], references: [userId], onDelete: Cascade)

  @@index([customerId])
}

model Delivery {
  id              Int     @id @default(autoincrement())
  orderId         Int     @unique
  shipperId       Int
  statusId        Int     @default(1) // 1: waiting, 2: picked_up, 3: delivering, 4: delivered
  pickupTime      DateTime?
  deliveryTime    DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  order           Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  shipper         Shipper @relation(fields: [shipperId], references: [userId], onDelete: Cascade)

  @@index([orderId])
  @@index([shipperId])
  @@index([statusId])
}

model Message {
  id              Int     @id @default(autoincrement())
  userId          Int
  content         String  @db.Text
  type            String  @db.VarChar(50) // 'chat', 'notification'
  createdAt       DateTime @default(now())

  user            User    @relation(fields: [userId], references: [userId], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
}

model Review {
  id              Int     @id @default(autoincrement())
  orderId         Int
  rating          Int     // 1-5
  comment         String? @db.Text
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([orderId])
  @@unique([orderId])
}
